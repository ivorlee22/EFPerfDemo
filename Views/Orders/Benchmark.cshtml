@model EFPerfDemo.Models.ComparisonViewModel
@{
    ViewData["Title"] = Model.Title;
    double speedup = Model.Solution.ElapsedMs > 0
        ? Math.Round((double)Model.PainPoint.ElapsedMs / Model.Solution.ElapsedMs, 1)
        : 0;
    double memorySaving = Model.PainPoint.MemoryBytes > 0 && Model.Solution.MemoryBytes > 0
        ? Math.Round((1 - (double)Model.Solution.MemoryBytes / Model.PainPoint.MemoryBytes) * 100, 0)
        : 0;
}

<div class="bench-page">

    <!-- Data Description Banner -->
    <div class="data-description">
        <i class="fa-solid fa-database"></i>
        This system runs with <strong>1,000</strong> customer records, <strong>5,008</strong> order records, and <strong>25,035</strong> order item records.
    </div>

    <!-- Header -->
    <div class="bench-header">
        <div class="back-link">
            <a asp-controller="Home" asp-action="Index">
                <i class="fa-solid fa-arrow-left"></i> All Scenarios
            </a>
            <span class="breadcrumb-sep">/</span>
            <span class="breadcrumb-cat">
                <i class="fa-solid fa-layer-group"></i>
                @Model.Category
            </span>
        </div>
        <h1 class="bench-title">@Model.Title</h1>
    </div>

    <!-- KPI Row -->
    <div class="kpi-row">
        <div class="kpi bad">
            <div class="kpi-icon"><i class="fa-solid fa-circle-xmark"></i></div>
            <span id="painQuery" class="kpi-val">—</span>
            <span class="kpi-lbl">Pain Queries</span>
        </div>
        <div class="kpi bad">
            <div class="kpi-icon"><i class="fa-solid fa-hourglass-half"></i></div>
            <span id="painTime" class="kpi-val">—</span>
            <span class="kpi-lbl">Pain Time</span>
        </div>
        <div class="kpi accent">
            <div class="kpi-icon"><i class="fa-solid fa-bolt"></i></div>
            <span id="speedup" class="kpi-val">—</span>
            <span class="kpi-lbl">Speedup</span>
        </div>
        <div class="kpi good">
            <div class="kpi-icon"><i class="fa-solid fa-circle-check"></i></div>
            <span id="solutionQuery" class="kpi-val">—</span>
            <span class="kpi-lbl">Solution Queries</span>
        </div>
        <div class="kpi good">
            <div class="kpi-icon"><i class="fa-solid fa-gauge-high"></i></div>
            <span id="solutionTime" class="kpi-val">—</span>
            <span class="kpi-lbl">Solution Time</span>
        </div>
        <div class="kpi good" id="memorySavingKpi" style="display:none">
            <div class="kpi-icon"><i class="fa-solid fa-memory"></i></div>
            <span id="memorySaving" class="kpi-val">—<small>%</small></span>
            <span class="kpi-lbl">Less Memory</span>
        </div>
    </div>

    <!-- Run Controls -->
    <div class="run-section">

        <!-- Pain Point Button -->
        <div class="run-btn-group">
            <button id="runPainBtn" class="run-btn run-btn--pain" title="Run Pain Point">
                <i class="fa-solid fa-skull-crossbones" id="runPainIcon"></i>
            </button>
            <div class="run-label">
                <span class="run-title bad-text">Run Pain Point</span>
                <span id="painStatus" class="run-status"></span>
            </div>
        </div>

        <!-- Solution Button -->
        <div class="run-btn-group">
            <button id="runSolBtn" class="run-btn run-btn--solution" title="Run Solution">
                <i class="fa-solid fa-wand-magic-sparkles" id="runSolIcon"></i>
            </button>
            <div class="run-label">
                <span class="run-title good-text">Run Solution</span>
                <span id="solStatus" class="run-status"></span>
            </div>
        </div>

        <!-- Reset Button -->
        <div class="run-btn-group">
            <button id="resetBtn" class="run-btn run-btn--reset" title="Reset Results">
                <i class="fa-solid fa-rotate-left" id="resetIcon"></i>
            </button>
            <div class="run-label">
                <span class="run-title">Reset</span>
                <span class="run-status"></span>
            </div>
        </div>

    </div>

    <input type="hidden" id="scenario" value="@ViewContext.RouteData.Values["action"]" />

     <!-- Timeline -->
    <div class="timeline-section">
        <div class="section-label"><i class="fa-solid fa-chart-gantt"></i> Execution Time Comparison</div>

        <div class="tl-row">
            <span class="tl-tag bad"><i class="fa-solid fa-bug"></i> PAIN</span>
            <div class="tl-track">
                <div id="painBar" class="tl-fill bad tl-pending" style="width: 100%">
                    <i class="fa-solid fa-hourglass-end"></i>
                    <span id="painBarLabel">Not run yet</span>
                </div>
            </div>
        </div>

        <div class="tl-row">
            <span class="tl-tag good"><i class="fa-solid fa-rocket"></i> FIX</span>
            <div class="tl-track">
                <div id="solutionBar" class="tl-fill good tl-pending" style="width: 50%">
                    <i class="fa-solid fa-check"></i>
                    <span id="solutionBarLabel">Not run yet</span>
                </div>
            </div>
        </div>
    </div>

    <!-- Code Compare -->
    <div class="compare-grid">

        <!-- Pain Point -->
        <div class="compare-panel pain">
            <div class="cp-header">
                <span class="badge bad"><i class="fa-solid fa-skull-crossbones"></i> PAIN POINT</span>
                <span class="cp-name">@Model.PainPoint.ScenarioName</span>
            </div>
            <pre class="code-block"><code>@Model.PainPoint.CodeSnippet</code></pre>
            @* <div class="cp-explain">
                <i class="fa-solid fa-triangle-exclamation cp-explain-icon bad-text"></i>
                @Model.PainPoint.PainPointExplanation
            </div> *@
            <div class="sql-label"><i class="fa-solid fa-terminal"></i> Generated SQL</div>
            <pre class="sql-block"><code>@Model.PainPoint.SqlGenerated</code></pre>

            @if (Model.PainPoint.QuerySteps.Any())
            {
                <div class="query-steps">
                    <div class="qs-title"><i class="fa-solid fa-stopwatch"></i> Query Breakdown</div>
                    @foreach (var (step, i) in Model.PainPoint.QuerySteps.Select((s, i) => (s, i)))
                    {
                        <div class="qs-row">
                            <div class="qs-label">
                                <span class="qs-num">@(i + 1)</span>
                                @step.Label
                            </div>
                            <pre class="qs-sql"><code>@step.Sql</code></pre>
                            <div class="qs-meta">
                                <span class="qs-time bad">
                                    <i class="fa-solid fa-clock"></i> @step.ElapsedMs ms
                                </span>
                                <span class="qs-rows">
                                    <i class="fa-solid fa-table-rows"></i> @step.RowCount rows
                                </span>
                            </div>
                        </div>
                    }
                </div>
            }
        </div>

        <!-- Solution -->
        <div class="compare-panel solution">
            <div class="cp-header">
                <span class="badge good"><i class="fa-solid fa-wand-magic-sparkles"></i> SOLUTION</span>
                <span class="cp-name">@Model.Solution.ScenarioName</span>
            </div>
            <pre class="code-block"><code>@Model.Solution.CodeSnippet</code></pre>
            @* <div class="cp-explain">
                <i class="fa-solid fa-circle-info cp-explain-icon good-text"></i>
                @Model.Solution.SolutionExplanation
            </div> *@
            <div class="sql-label"><i class="fa-solid fa-terminal"></i> Generated SQL</div>
            <pre class="sql-block"><code>@Model.Solution.SqlGenerated</code></pre>
        </div>

    </div>

</div>

<style>
    /* ── Extra styles for the new dual-button layout ── */
    .run-section {
        display: flex;
        align-items: center;
        gap: 1.5rem;
        flex-wrap: wrap;
    }
    .run-btn-group {
        display: flex;
        align-items: center;
        gap: 0.75rem;
    }
    .run-btn--pain {
        background: var(--color-bad, #ef4444) !important;
    }
    .run-btn--pain:hover:not(:disabled) {
        filter: brightness(1.15);
    }
    .run-btn--solution {
        background: var(--color-good, #22c55e) !important;
    }
    .run-btn--solution:hover:not(:disabled) {
        filter: brightness(1.15);
    }
    .run-btn--reset {
        background: var(--color-muted, #6b7280) !important;
    }
    .run-btn--reset:hover:not(:disabled) {
        filter: brightness(1.2);
    }
    .tl-pending {
        opacity: 0.4;
    }
    .bad-text  { color: var(--color-bad,  #ef4444); }
    .good-text { color: var(--color-good, #22c55e); }
</style>

<script>
    const scenario      = document.getElementById("scenario").value;

    // ── KPI element refs ──────────────────────────────────────────────────
    const elPainQuery   = document.getElementById("painQuery");
    const elPainTime    = document.getElementById("painTime");
    const elSolQuery    = document.getElementById("solutionQuery");
    const elSolTime     = document.getElementById("solutionTime");
    const elSpeedup     = document.getElementById("speedup");
    const elMemSaving   = document.getElementById("memorySaving");
    const elMemKpi      = document.getElementById("memorySavingKpi");

    // ── Timeline refs ─────────────────────────────────────────────────────
    const painBar       = document.getElementById("painBar");
    const solBar        = document.getElementById("solutionBar");
    const painBarLabel  = document.getElementById("painBarLabel");
    const solBarLabel   = document.getElementById("solutionBarLabel");

    // ── Button / status refs ──────────────────────────────────────────────
    const runPainBtn    = document.getElementById("runPainBtn");
    const runSolBtn     = document.getElementById("runSolBtn");
    const resetBtn      = document.getElementById("resetBtn");
    const runPainIcon   = document.getElementById("runPainIcon");
    const runSolIcon    = document.getElementById("runSolIcon");
    const painStatus    = document.getElementById("painStatus");
    const solStatus     = document.getElementById("solStatus");

    // ── State ─────────────────────────────────────────────────────────────
    let painMs    = null;
    let solutionMs = null;
    let painMem   = null;
    let solMem    = null;

    // ── Helper: call RunStep endpoint ─────────────────────────────────────
    async function runStep(step) {
        const res = await fetch('/Orders/RunStep', {
            method:  'POST',
            headers: { 'Content-Type': 'application/json' },
            body:    JSON.stringify({ scenario, step })
        });
        if (!res.ok) throw new Error(`HTTP ${res.status}`);
        return res.json();
    }

    // ── Helper: update speedup + memory KPIs after both sides are run ─────
    function refreshDerivedKpis() {
        if (painMs !== null && solutionMs !== null) {
            const sp = solutionMs > 0 ? (painMs / solutionMs).toFixed(1) : "∞";
            elSpeedup.innerHTML = sp + "<small>×</small>";

            // Resize timeline bars
            const pct = solutionMs > 0
                ? Math.max(3, Math.round((solutionMs / painMs) * 100))
                : 3;
            painBar.style.width = "100%";
            solBar.style.width  = pct + "%";
        }
        if (painMem !== null && solMem !== null && painMem > 0) {
            const mem = Math.round((1 - solMem / painMem) * 100);
            if (mem > 0) {
                elMemSaving.innerHTML  = mem + "<small>%</small>";
                elMemKpi.style.display = "";
            }
        }
    }

    // ── Helper: set a button into loading / done / error state ───────────
    function setBtnLoading(btn, icon, isLoading, iconClass = null) {
        btn.disabled = isLoading;
        btn.classList.toggle("running", isLoading);
        icon.className = isLoading
            ? "fa-solid fa-spinner fa-spin"
            : (iconClass ?? "fa-solid fa-rotate-right");
    }

    // ── RUN PAIN POINT ────────────────────────────────────────────────────
    runPainBtn.addEventListener("click", async () => {
        setBtnLoading(runPainBtn, runPainIcon, true);
        painStatus.innerHTML  = '<i class="fa-solid fa-circle-notch fa-spin"></i> Measuring…';
        painStatus.className  = "run-status";
        painBar.classList.add("tl-pending");

        try {
            const data = await runStep("pain");
            painMs  = data.elapsedMs;
            painMem = data.memoryBytes;

            elPainTime.innerHTML  = data.elapsedMs + "<small>ms</small>";
            elPainQuery.innerText = data.queryCount;

            painBar.classList.remove("tl-pending");
            painBarLabel.textContent = `${data.elapsedMs} ms — ${data.queryCount} queries`;

            painStatus.innerHTML = '<i class="fa-solid fa-circle-check"></i> Done!';
            painStatus.className = "run-status success";
            refreshDerivedKpis();
        } catch (err) {
            console.error(err);
            painStatus.innerHTML = '<i class="fa-solid fa-circle-xmark"></i> Error';
            painStatus.className = "run-status error";
        }

        setBtnLoading(runPainBtn, runPainIcon, false, "fa-solid fa-skull-crossbones");
    });

    // ── RUN SOLUTION ──────────────────────────────────────────────────────
    runSolBtn.addEventListener("click", async () => {
        setBtnLoading(runSolBtn, runSolIcon, true);
        solStatus.innerHTML  = '<i class="fa-solid fa-circle-notch fa-spin"></i> Measuring…';
        solStatus.className  = "run-status";
        solBar.classList.add("tl-pending");

        try {
            const data = await runStep("solution");
            solutionMs = data.elapsedMs;
            solMem     = data.memoryBytes;

            elSolTime.innerHTML  = data.elapsedMs + "<small>ms</small>";
            elSolQuery.innerText = data.queryCount;

            solBar.classList.remove("tl-pending");
            solBarLabel.textContent = `${data.elapsedMs} ms — ${data.queryCount} queries`;

            solStatus.innerHTML = '<i class="fa-solid fa-circle-check"></i> Done!';
            solStatus.className = "run-status success";
            refreshDerivedKpis();
        } catch (err) {
            console.error(err);
            solStatus.innerHTML = '<i class="fa-solid fa-circle-xmark"></i> Error';
            solStatus.className = "run-status error";
        }

        setBtnLoading(runSolBtn, runSolIcon, false, "fa-solid fa-wand-magic-sparkles");
    });

    // ── RESET ─────────────────────────────────────────────────────────────
    resetBtn.addEventListener("click", () => {
        // Clear state
        painMs = solutionMs = painMem = solMem = null;

        // KPIs → placeholder
        elPainTime.innerHTML    = "—";
        elPainQuery.innerText   = "—";
        elSolTime.innerHTML     = "—";
        elSolQuery.innerText    = "—";
        elSpeedup.innerHTML     = "—";
        elMemKpi.style.display  = "none";

        // Status labels
        painStatus.innerHTML = "";
        painStatus.className = "run-status";
        solStatus.innerHTML  = "";
        solStatus.className  = "run-status";

        // Timeline → pending
        painBar.classList.add("tl-pending");
        solBar.classList.add("tl-pending");
        painBar.style.width      = "100%";
        solBar.style.width       = "50%";
        painBarLabel.textContent = "Not run yet";
        solBarLabel.textContent  = "Not run yet";

        // Re-arm icons
        runPainIcon.className = "fa-solid fa-skull-crossbones";
        runSolIcon.className  = "fa-solid fa-wand-magic-sparkles";
    });

    function setLoading(buttonId, iconId, statusId, text) {
    const btn = document.getElementById(buttonId);
    const icon = document.getElementById(iconId);
    const status = document.getElementById(statusId);

    btn.disabled = true;
    icon.classList.add("loading");
    status.innerText = text;
}

function stopLoading(buttonId, iconId, statusId, text) {
    const btn = document.getElementById(buttonId);
    const icon = document.getElementById(iconId);
    const status = document.getElementById(statusId);

    btn.disabled = false;
    icon.classList.remove("loading");
    status.innerText = text;
}
</script>
